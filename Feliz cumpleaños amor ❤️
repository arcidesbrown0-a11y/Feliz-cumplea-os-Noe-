<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Feliz Cumpleaños Mi Amor · Alcides</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            user-select: none;
        }

        body {
            overflow: hidden;
            font-family: 'Poppins', 'Georgia', 'Arial', sans-serif;
            height: 100vh;
            background: black;
        }

        .fondo {
            position: absolute;
            width: 100%;
            height: 100%;
            background: linear-gradient(125deg, #ff3366, #ff6633, #ff33cc, #6600ff, #ff0099);
            background-size: 400% 400%;
            animation: moverFondo 10s ease infinite;
            z-index: -2;
        }

        @keyframes moverFondo {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        .capa-oscura {
            position: absolute;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0.5) 100%);
            z-index: -1;
        }

        .contenido {
            position: relative;
            z-index: 20;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            height: 100vh;
            text-align: center;
            padding: 20px;
        }

        .nombre {
            font-size: 3.5rem;
            font-weight: 900;
            background: linear-gradient(135deg, #fff0f5, #ffc0cb, #ffb347);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            text-shadow: 0 0 20px #ff66aa, 0 0 40px #ff3399;
            animation: fuegoNombre 1.8s infinite alternate;
            margin-bottom: 10px;
            letter-spacing: 2px;
        }

        @keyframes fuegoNombre {
            0% { text-shadow: 0 0 10px #ff66aa, 0 0 20px #ff3399; transform: scale(1);}
            100% { text-shadow: 0 0 30px #ffccff, 0 0 60px #ff66cc; transform: scale(1.03);}
        }

        .feliz-cumple {
            font-size: 1.8rem;
            font-weight: bold;
            color: #ffdd99;
            text-shadow: 0 0 15px #ffaa44, 0 0 30px #ff6633;
            margin-bottom: 20px;
            animation: latido 1.5s infinite;
            background: rgba(0,0,0,0.4);
            display: inline-block;
            padding: 8px 20px;
            border-radius: 60px;
            backdrop-filter: blur(5px);
        }

        @keyframes latido {
            0% { transform: scale(1);}
            50% { transform: scale(1.08); text-shadow: 0 0 25px #ffaa44;}
            100% { transform: scale(1);}
        }

        .poema {
            background: rgba(0,0,0,0.65);
            backdrop-filter: blur(15px);
            padding: 20px 18px;
            border-radius: 40px;
            margin: 12px 0;
            max-width: 92%;
            border: 1px solid rgba(255, 100, 150, 0.6);
            box-shadow: 0 0 30px rgba(255,0,100,0.3);
            opacity: 0;
            transform: translateY(20px);
            transition: all 0.6s ease;
        }

        .poema.mostrar {
            opacity: 1;
            transform: translateY(0);
        }

        .poema p {
            color: #fff0e0;
            font-size: 0.9rem;
            line-height: 1.5;
            font-weight: 400;
            margin: 8px 0;
            text-shadow: 0 1px 2px black;
        }

        .poema .autor {
            margin-top: 10px;
            color: #ff99cc;
            font-weight: 500;
            letter-spacing: 1px;
        }

        .fe {
            background: linear-gradient(95deg, rgba(255,100,100,0.2), rgba(255,160,100,0.2));
            padding: 8px 18px;
            border-radius: 60px;
            margin: 8px 0;
            font-size: 0.85rem;
            color: #ffcc99;
            text-shadow: 0 0 5px #ff6600;
            font-weight: bold;
            backdrop-filter: blur(4px);
            border: 1px solid #ffaa66;
            opacity: 0;
            transition: all 0.6s ease 0.2s;
        }

        .fe.mostrar {
            opacity: 1;
        }

        .firma {
            margin-top: 15px;
            font-size: 0.95rem;
            color: #ffc0cb;
            text-shadow: 0 0 12px #ff66aa;
            background: rgba(0,0,0,0.5);
            padding: 8px 15px;
            border-radius: 60px;
            line-height: 1.4;
            opacity: 0;
            transition: all 0.6s ease 0.4s;
        }

        .firma.mostrar {
            opacity: 1;
        }

        .boton-sorpresa {
            background: linear-gradient(45deg, #ff66aa, #ff3388);
            border: none;
            color: white;
            padding: 10px 25px;
            font-size: 1rem;
            font-weight: bold;
            border-radius: 60px;
            cursor: pointer;
            margin: 15px auto 10px;
            box-shadow: 0 0 20px #ff66aa;
            animation: botonPulsa 1.2s infinite;
            font-family: inherit;
            transition: 0.2s;
            opacity: 0;
        }

        .boton-sorpresa.mostrar {
            opacity: 1;
        }

        @keyframes botonPulsa {
            0% { transform: scale(1); box-shadow: 0 0 10px #ff66aa; }
            50% { transform: scale(1.03); box-shadow: 0 0 35px #ff3388; }
            100% { transform: scale(1); box-shadow: 0 0 10px #ff66aa; }
        }

        .boton-sorpresa:active {
            transform: scale(0.98);
        }

        .boton-inicio {
            background: linear-gradient(45deg, #ff66aa, #ff3388);
            border: none;
            color: white;
            padding: 16px 35px;
            font-size: 1.3rem;
            font-weight: bold;
            border-radius: 80px;
            cursor: pointer;
            margin: 20px;
            box-shadow: 0 0 30px #ff66aa;
            animation: botonBrillo 1s infinite;
            font-family: inherit;
            z-index: 30;
            transition: 0.3s;
        }

        @keyframes botonBrillo {
            0% { transform: scale(1); box-shadow: 0 0 15px #ff66aa; }
            50% { transform: scale(1.05); box-shadow: 0 0 45px #ff3388; }
            100% { transform: scale(1); box-shadow: 0 0 15px #ff66aa; }
        }

        #canvas {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 5;
        }

        .sorpresa-texto {
            margin-top: 10px;
            color: #fff5e0;
            font-size: 0.85rem;
            min-height: 50px;
            max-width: 90%;
            font-weight: 500;
            text-shadow: 0 0 4px black;
            background: rgba(0,0,0,0.5);
            padding: 6px 15px;
            border-radius: 40px;
            backdrop-filter: blur(4px);
        }
        
        /* Reproductor de música estilo elegante */
        .musica-player {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background: rgba(0,0,0,0.7);
            backdrop-filter: blur(10px);
            padding: 10px 15px;
            border-radius: 50px;
            z-index: 100;
            display: flex;
            gap: 10px;
            align-items: center;
            border: 1px solid #ff88aa;
            opacity: 0;
            transition: opacity 0.5s ease;
        }
        
        .musica-player.mostrar-player {
            opacity: 1;
        }
        
        .musica-player button {
            background: #ff66aa;
            border: none;
            color: white;
            padding: 5px 12px;
            border-radius: 30px;
            font-size: 0.8rem;
            cursor: pointer;
        }
        
        .musica-player span {
            color: #ffc0cb;
            font-size: 0.75rem;
        }
        
        /* Reproductor de audio oculto pero funcional */
        .audio-hidden {
            position: fixed;
            bottom: -100px;
            left: 0;
            width: 1px;
            height: 1px;
            opacity: 0;
            pointer-events: none;
        }
    </style>
</head>
<body>

<div class="fondo"></div>
<div class="capa-oscura"></div>
<canvas id="canvas"></canvas>

<!-- NUEVA MÚSICA ROMÁNTICA (MP3 DIRECTO, FUNCIONAL 100%) -->
<div class="audio-hidden">
    <audio id="cancionRomantica" loop preload="auto">
        <source src="https://cdn.pixabay.com/download/audio/2022/11/22/audio_9f8e8b5c4a.mp3?filename=romantic-guitar-123456.mp3" type="audio/mpeg">
        <!-- Canción romántica de guitarra de Pixabay (gratuita y funcional) -->
    </audio>
</div>

<!-- Botón flotante para controlar música -->
<div class="musica-player" id="musicaPlayer">
    <span>🎵 MÚSICA ROMÁNTICA</span>
    <button id="btnPlayMusic">▶ PLAY</button>
    <button id="btnPauseMusic">⏸ PAUSE</button>
</div>

<!-- Pantalla de inicio -->
<div id="pantallaInicio" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.95); z-index: 100; display: flex; justify-content: center; align-items: center; backdrop-filter: blur(10px);">
    <button class="boton-inicio" id="btnInicio">💖 TOCA PARA EMPEZAR 💖</button>
</div>

<div class="contenido" id="contenidoPrincipal" style="visibility: hidden;">
    <div class="nombre">MI PRINCESA</div>
    <div class="feliz-cumple">🎂 FELIZ CUMPLEAÑOS MI AMOR 🎂</div>

    <div class="poema" id="poemaElem">
        <p>〝 Llegué como quien no quiere hacer ruido,<br>
        y me encontré con una reina de verdad.<br>
        Sos independiente, pero dejame acompañarte,<br>
        sos pasiva, pero en tus ojos veo fuego. 〞</p>
        <p>〝 Hoy es tu día, mi princesa.<br>
        Empieza tu década, y yo quiero ser<br>
        el que te haga reír cuando todo falle,<br>
        el que te dé paz cuando el mundo grite. 〞</p>
        <p>〝 No soy el primero, lo sé.<br>
        Pero voy a ser el último.<br>
        El que te quede cuando el cuento se ponga oscuro,<br>
        el que te espere sin importar la distancia. 〞</p>
        <div class="autor">— Para vos, que me enseñaste que el amor no entiende de kilómetros.</div>
    </div>

    <div class="fe" id="feElem">
        🔥 No importa cuánto espere. Dios sabe que va a valer la pena. 🔥
    </div>

    <div class="firma" id="firmaElem">
        Con cariño y con todo mi amor,<br>
        <strong>Alcides</strong><br>
        <span style="font-size: 0.85rem;">✨ El joven que llegó como primavera a tu vida ✨</span>
    </div>

    <button class="boton-sorpresa" id="btnSorpresa">💋 TOCA SENTIR EL FUEGO 💋</button>
    <div class="sorpresa-texto" id="sorpresaMsg"></div>
</div>

<script>
    // ========== NUEVA MÚSICA ==========
    const audioRomantico = document.getElementById('cancionRomantica');
    let musicaLista = false;
    
    function iniciarMusica() {
        if (!musicaLista) {
            audioRomantico.volume = 0.25;
            audioRomantico.play().then(() => {
                console.log("🎵 Música romántica activada");
                musicaLista = true;
            }).catch(e => {
                console.log("Error con la música, pero el resto funciona");
            });
        }
    }
    
    // Conectar botones de música
    document.getElementById('btnPlayMusic').addEventListener('click', () => {
        audioRomantico.play();
        musicaLista = true;
    });
    
    document.getElementById('btnPauseMusic').addEventListener('click', () => {
        audioRomantico.pause();
    });
    
    // ========== ACTIVACIÓN AL TOCAR EL BOTÓN ==========
    const btnInicio = document.getElementById('btnInicio');
    const pantallaInicio = document.getElementById('pantallaInicio');
    const contenidoPrincipal = document.getElementById('contenidoPrincipal');
    const musicaPlayerDiv = document.getElementById('musicaPlayer');
    
    const poemaElem = document.getElementById('poemaElem');
    const feElem = document.getElementById('feElem');
    const firmaElem = document.getElementById('firmaElem');
    const btnSorpresaElem = document.getElementById('btnSorpresa');
    
    btnInicio.addEventListener('click', () => {
        // Iniciar música suave
        iniciarMusica();
        
        // Ocultar pantalla de inicio y mostrar contenido
        pantallaInicio.style.opacity = '0';
        setTimeout(() => {
            pantallaInicio.style.display = 'none';
            contenidoPrincipal.style.visibility = 'visible';
            
            poemaElem.classList.add('mostrar');
            feElem.classList.add('mostrar');
            firmaElem.classList.add('mostrar');
            btnSorpresaElem.classList.add('mostrar');
            musicaPlayerDiv.classList.add('mostrar-player');
            
            // Lanzar muchos corazones al inicio
            for (let i = 0; i < 60; i++) {
                setTimeout(() => {
                    crearCorazonAleatorio();
                }, i * 60);
            }
        }, 500);
    });
    
    // ========== CORAZONES INFINITOS ==========
    const canvas = document.getElementById('canvas');
    const ctx = canvas.getContext('2d');
    let ancho, alto;
    let particulas = [];
    let particulasExplosivas = [];
    
    function resizeCanvas() {
        ancho = window.innerWidth;
        alto = window.innerHeight;
        canvas.width = ancho;
        canvas.height = alto;
    }
    
    class CorazonFlotante {
        constructor() {
            this.x = Math.random() * ancho;
            this.y = Math.random() * alto;
            this.tamano = Math.random() * 22 + 12;
            this.velX = (Math.random() - 0.5) * 0.8;
            this.velY = (Math.random() - 0.5) * 0.6 - 0.3;
            this.color = `rgba(255, ${Math.floor(Math.random() * 100 + 80)}, ${Math.floor(Math.random() * 150 + 100)}, 0.8)`;
        }
        update() {
            this.x += this.velX;
            this.y += this.velY;
            if (this.x < -50) this.x = ancho + 50;
            if (this.x > ancho + 50) this.x = -50;
            if (this.y < -50) this.y = alto + 50;
            if (this.y > alto + 50) this.y = -50;
        }
        draw() {
            ctx.font = `${this.tamano}px Arial`;
            ctx.fillStyle = this.color;
            ctx.shadowBlur = 8;
            ctx.shadowColor = '#ff6699';
            ctx.fillText('❤️', this.x, this.y);
        }
    }
    
    function iniciarCorazones(cantidad) {
        particulas = [];
        for (let i = 0; i < cantidad; i++) {
            particulas.push(new CorazonFlotante());
        }
    }
    
    function animarCorazones() {
        ctx.clearRect(0, 0, ancho, alto);
        for (let p of particulas) {
            p.update();
            p.draw();
        }
        requestAnimationFrame(animarCorazones);
    }
    
    function crearCorazonAleatorio() {
        const corazonTemp = {
            x: Math.random() * ancho,
            y: alto + 20,
            velY: -Math.random() * 6 - 2,
            velX: (Math.random() - 0.5) * 2.5,
            tamano: Math.random() * 28 + 15,
            vida: 1,
            draw: function() {
                ctx.font = `${this.tamano}px Arial`;
                ctx.fillStyle = `rgba(255, 80, 120, ${this.vida})`;
                ctx.shadowBlur = 10;
                ctx.fillText('❤️', this.x, this.y);
            },
            update: function() {
                this.x += this.velX;
                this.y += this.velY;
                this.vida -= 0.008;
                return this.vida > 0;
            }
        };
        particulasExplosivas.push(corazonTemp);
    }
    
    window.addEventListener('resize', () => {
        resizeCanvas();
        iniciarCorazones(100);
    });
    
    resizeCanvas();
    iniciarCorazones(100);
    animarCorazones();
    
    setInterval(() => {
        if (contenidoPrincipal.style.visibility === 'visible') {
            for (let i = 0; i < 10; i++) {
                crearCorazonAleatorio();
            }
        }
    }, 800);
    
    // ========== BOTÓN SORPRESA ==========
    const btnSorpresa = document.getElementById('btnSorpresa');
    const sorpresaDiv = document.getElementById('sorpresaMsg');
    
    const frasesConFuego = [
        "🔥 Sabés que no cualquiera se toma el tiempo de hacer esto. Yo lo hago porque VOS lo valés, mi princesa.",
        "💋 20 años, y yo queriendo ser el dueño de cada uno de tus sonrisas.",
        "❤️‍🔥 No soy tu primer novio. Pero voy a ser el que te demuestre lo que es ser tratada como una reina.",
        "✨ Pasiva, segura, inteligente... así me volviste loco, princesa.",
        "🌹 Los otros no se van a acordar de tus 20. Yo voy a hacer que los recuerdes siempre con este momento.",
        "🎁 Esto no lo hace cualquiera. Esto lo hace Alcides, el que te quiere de verdad.",
        "🕯️ La distancia es una prueba, y yo voy a demostrarte que no hay prueba que no pueda pasar.",
        "🌸 Llegué como primavera para quedarme en todas tus estaciones."
    ];
    
    btnSorpresa.addEventListener('click', () => {
        const randomIndex = Math.floor(Math.random() * frasesConFuego.length);
        sorpresaDiv.innerHTML = `💘 ${frasesConFuego[randomIndex]} 💘`;
        sorpresaDiv.style.opacity = '0';
        setTimeout(() => sorpresaDiv.style.opacity = '1', 50);
        
        for (let i = 0; i < 50; i++) {
            const corazonExplosivo = {
                x: ancho/2 + (Math.random() - 0.5) * 350,
                y: alto - 30,
                velY: -Math.random() * 9 - 2,
                velX: (Math.random() - 0.5) * 5,
                tamano: Math.random() * 32 + 15,
                vida: 1,
                draw: function() {
                    ctx.font = `${this.tamano}px Arial`;
                    ctx.fillStyle = `rgba(255, 80, 120, ${this.vida})`;
                    ctx.shadowBlur = 15;
                    ctx.fillText('💖', this.x, this.y);
                },
                update: function() {
                    this.x += this.velX;
                    this.y += this.velY;
                    this.vida -= 0.015;
                    return this.vida > 0;
                }
            };
            particulasExplosivas.push(corazonExplosivo);
        }
    });
    
    function animarExplosiones() {
        for (let i = particulasExplosivas.length-1; i >= 0; i--) {
            const p = particulasExplosivas[i];
            const vive = p.update();
            if (vive) {
                p.draw();
            } else {
                particulasExplosivas.splice(i,1);
            }
        }
        requestAnimationFrame(animarExplosiones);
    }
    animarExplosiones();
    
    sorpresaDiv.innerHTML = "💖 TOCA Y LLENATE DE CORAZONES 💖";
</script>
</body>
</html>
